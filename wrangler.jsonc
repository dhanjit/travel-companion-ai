{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "travel-companion-ai",
  "compatibility_date": "2026-06-01",
  // Static mockup site only — serves site/ at the root. No build step, no
  // API key needed. To deploy the real Next.js app instead, replace this
  // file's contents with wrangler.opennext.jsonc and set the
  // ANTHROPIC_API_KEY secret on the Worker.
  "assets": {
    "directory": "./site"
  }
}
